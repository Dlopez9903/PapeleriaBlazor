@page "/clientes"
@using PapeleriaBlazor.Services
@using PapeleriaBlazor.Models
@inject ClienteService ClienteSvc

<PageTitle>Clientes — El Lápiz Feliz</PageTitle>

<div class="page-header">
    <div class="page-title-area">
        <h1 class="page-title">Gestión de Clientes</h1>
        <p class="page-subtitle">Alta, consulta, edición y eliminación</p>
    </div>
    <button class="btn btn-primary" @onclick="NuevoCliente">
        <i class="fa-solid fa-user-plus"></i> Nuevo Cliente
    </button>
</div>

<!-- ── Mensaje de éxito / error ───────────────────────────────────── -->
@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert @(esError ? "alert-danger" : "alert-success")">
        <i class="fa-solid @(esError ? "fa-circle-xmark" : "fa-circle-check")"></i>
        @mensaje
        <button class="alert-close" @onclick="() => mensaje = string.Empty">✕</button>
    </div>
}

<!-- ── Formulario (alta / edición) ────────────────────────────────── -->
@if (mostrarFormulario)
{
    <div class="form-card">
        <h2 class="form-title">
            <i class="fa-solid @(clienteEditando.Id == 0 ? "fa-user-plus" : "fa-user-pen")"></i>
            @(clienteEditando.Id == 0 ? "Nuevo Cliente" : "Editar Cliente")
        </h2>

        <EditForm Model="clienteEditando" OnValidSubmit="GuardarCliente">
            <DataAnnotationsValidator />

            <div class="form-grid">
                <div class="form-group">
                    <label>Nombre completo *</label>
                    <InputText class="form-input" @bind-Value="clienteEditando.Nombre"
                               placeholder="Ej. María González" />
                    <ValidationMessage For="@(() => clienteEditando.Nombre)" />
                </div>

                <div class="form-group">
                    <label>Teléfono *</label>
                    <InputText class="form-input" @bind-Value="clienteEditando.Telefono"
                               placeholder="Ej. 3121234567" />
                    <ValidationMessage For="@(() => clienteEditando.Telefono)" />
                </div>

                <div class="form-group form-full">
                    <label>Correo electrónico *</label>
                    <InputText class="form-input" @bind-Value="clienteEditando.Email"
                               placeholder="cliente@ejemplo.com" />
                    <ValidationMessage For="@(() => clienteEditando.Email)" />
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i>
                    @(clienteEditando.Id == 0 ? "Guardar" : "Actualizar")
                </button>
                <button type="button" class="btn btn-ghost" @onclick="Cancelar">
                    Cancelar
                </button>
            </div>
        </EditForm>
    </div>
}

<!-- ── Lista de clientes ──────────────────────────────────────────── -->
@if (clientes == null)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <p>Cargando clientes...</p>
    </div>
}
else if (clientes.Count == 0)
{
    <div class="empty-state">
        <i class="fa-solid fa-users-slash"></i>
        <p>No hay clientes registrados. ¡Agrega el primero!</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Fecha registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in clientes)
                {
                    <tr>
                        <td><span class="id-badge">@c.Id</span></td>
                        <td><strong>@c.Nombre</strong></td>
                        <td>@c.Telefono</td>
                        <td>@c.Email</td>
                        <td>@c.FechaRegistro.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="action-btns">
                                <button class="btn btn-sm btn-outline" @onclick="() => EditarCliente(c)"
                                        title="Editar">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn btn-sm btn-danger-outline" @onclick="() => ConfirmarEliminar(c)"
                                        title="Eliminar">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- ── Modal de confirmación de eliminación ───────────────────────── -->
@if (clienteAEliminar != null)
{
    <div class="modal-overlay" @onclick="CancelarEliminar">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-icon danger">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h3>¿Eliminar cliente?</h3>
            <p>Estás a punto de eliminar a <strong>@clienteAEliminar.Nombre</strong>.<br/>
               Esta acción no se puede deshacer.</p>
            <div class="modal-actions">
                <button class="btn btn-danger" @onclick="EliminarCliente">
                    Sí, eliminar
                </button>
                <button class="btn btn-ghost" @onclick="CancelarEliminar">
                    Cancelar
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Cliente>? clientes;
    private Cliente clienteEditando = new();
    private Cliente? clienteAEliminar;
    private bool mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool esError = false;

    protected override async Task OnInitializedAsync()
        => await CargarClientes();

    private async Task CargarClientes()
        => clientes = await ClienteSvc.GetTodosAsync();

    private void NuevoCliente()
    {
        clienteEditando = new Cliente();
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarCliente(Cliente c)
    {
        // Copia para no mutar la lista directamente
        clienteEditando = new Cliente
        {
            Id            = c.Id,
            Nombre        = c.Nombre,
            Telefono      = c.Telefono,
            Email         = c.Email,
            FechaRegistro = c.FechaRegistro
        };
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarCliente()
    {
        try
        {
            if (clienteEditando.Id == 0)
            {
                await ClienteSvc.AgregarAsync(clienteEditando);
                mensaje = "✅ Cliente registrado exitosamente.";
            }
            else
            {
                await ClienteSvc.ActualizarAsync(clienteEditando);
                mensaje = "✅ Cliente actualizado correctamente.";
            }
            esError = false;
            mostrarFormulario = false;
            await CargarClientes();
        }
        catch (Exception ex)
        {
            mensaje  = $"Error: {ex.Message}";
            esError  = true;
        }
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        clienteEditando   = new Cliente();
    }

    private void ConfirmarEliminar(Cliente c) => clienteAEliminar = c;
    private void CancelarEliminar()           => clienteAEliminar = null;

    private async Task EliminarCliente()
    {
        if (clienteAEliminar == null) return;
        try
        {
            await ClienteSvc.EliminarAsync(clienteAEliminar.Id);
            mensaje  = $"✅ Cliente '{clienteAEliminar.Nombre}' eliminado.";
            esError  = false;
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
            esError = true;
        }
        clienteAEliminar = null;
        await CargarClientes();
    }
}
